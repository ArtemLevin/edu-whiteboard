APP_NAME=Edu Whiteboard API
APP_ENV=local
APP_DEBUG=true
API_V1_PREFIX=/api/v1
DATABASE_URL=postgresql+asyncpg://edu:edu@postgres:5432/edu_whiteboard
REDIS_URL=redis://redis:6379/0
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
LOG_LEVEL=INFO
KAFKA_ENABLED=false
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
